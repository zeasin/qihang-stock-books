<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.qihangerp.mapper.OOrderItemMapper">

    <resultMap id="BaseResultMap" type="cn.qihangerp.model.entity.OOrderItem">
            <id property="id" column="id" jdbcType="BIGINT"/>
            <result property="orderId" column="order_id" jdbcType="BIGINT"/>
            <result property="subOrderNum" column="sub_order_num" jdbcType="VARCHAR"/>
            <result property="skuId" column="sku_id" jdbcType="VARCHAR"/>
            <result property="goodsId" column="goods_id" jdbcType="BIGINT"/>
            <result property="goodsSkuId" column="goods_sku_id" jdbcType="BIGINT"/>
            <result property="goodsTitle" column="goods_title" jdbcType="VARCHAR"/>
            <result property="goodsImg" column="goods_img" jdbcType="VARCHAR"/>
            <result property="goodsNum" column="goods_num" jdbcType="VARCHAR"/>
            <result property="goodsSpec" column="goods_spec" jdbcType="VARCHAR"/>
            <result property="skuNum" column="sku_num" jdbcType="VARCHAR"/>
            <result property="barcode" column="barcode" jdbcType="VARCHAR"/>
            <result property="goodsPrice" column="goods_price" jdbcType="DOUBLE"/>
            <result property="itemAmount" column="item_amount" jdbcType="DOUBLE"/>
            <result property="discountAmount" column="discount_amount" jdbcType="DOUBLE"/>
            <result property="payment" column="payment" jdbcType="DOUBLE"/>
            <result property="quantity" column="quantity" jdbcType="INTEGER"/>
            <result property="remark" column="remark" jdbcType="VARCHAR"/>
            <result property="refundCount" column="refund_count" jdbcType="INTEGER"/>
            <result property="refundStatus" column="refund_status" jdbcType="INTEGER"/>
<!--            <result property="orderStatus" column="order_status" jdbcType="INTEGER"/>-->
            <result property="hasPushErp" column="has_push_erp" jdbcType="INTEGER"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
            <result property="createBy" column="create_by" jdbcType="VARCHAR"/>
            <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
            <result property="updateBy" column="update_by" jdbcType="VARCHAR"/>
            <result property="shipType" column="ship_type" jdbcType="INTEGER"/>
            <result property="shipStatus" column="ship_status" jdbcType="INTEGER"/>
        <result property="productId" column="product_id" jdbcType="VARCHAR"/>
        <result property="waybillCode" column="waybill_code" jdbcType="VARCHAR"/>
        <result property="waybillCompany" column="waybill_company" jdbcType="VARCHAR"/>
        <result property="orderTime" column="order_time" jdbcType="INTEGER"/>
        <result property="shipperId" column="shipper_id" jdbcType="BIGINT"/>
        <result property="shipperNo" column="shipper_no" jdbcType="VARCHAR"/>
        <result property="shipperName" column="shipper_name" jdbcType="VARCHAR"/>
        <result property="shipperType" column="shipper_type" jdbcType="VARCHAR"/>
        <result property="shopId" column="shop_id" jdbcType="BIGINT"/>
        <result property="shopType" column="shop_type" jdbcType="INTEGER"/>
        <result property="isGift" column="is_gift" jdbcType="INTEGER"/>
        <result property="merchantId" column="merchant_id" jdbcType="BIGINT"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,order_id,sub_order_num,ship_status,ship_type,
        sku_id,goods_id,goods_sku_id,waybill_code,order_time,waybill_company,
        goods_title,goods_img,goods_num,product_id,barcode,
        goods_spec,sku_num,goods_price,discount_amount,
        item_amount,payment,quantity,remark,shipper_id,shipper_no,shipper_name,shipper_type,
        refund_count,refund_status,has_push_erp,create_time,
        create_by,update_time,update_by,merchant_id,shop_type,shop_id,is_gift
    </sql>

    <select id="selectPageVo" parameterType="cn.qihangerp.model.query.OrderItemQuery" resultType="cn.qihangerp.model.vo.OrderItemListVo">
        SELECT
        oi.id,oi.order_id,oi.order_num,oi.sub_order_num,oi.ship_status,oi.ship_type,oi.shipper_id,oi.shipper_name,oi.shipper_no,oi.shipper_type,oi.barcode,
        oi.sku_id,oi.goods_id,oi.goods_sku_id,oi.waybill_code,oi.order_time,oi.waybill_company,
        oi.goods_title,oi.goods_img,oi.goods_num,oi.product_id,
        oi.goods_spec,oi.sku_num,oi.goods_price,oi.discount_amount,
        oi.item_amount,oi.payment,oi.quantity,oi.remark,
        oi.refund_count,oi.refund_status,oi.has_push_erp,oi.create_time,
        oi.create_by,oi.update_time,oi.update_by,oi.merchant_id,oi.shop_type,oi.shop_id,oi.is_gift
             ,o.order_status
        FROM o_order_item as oi
        left join o_order as o on o.id = oi.order_id

        WHERE 1=1
        <if test="qw.shopId!=null">
           and o.shop_id = #{qw.shopId}
        </if>
        <if test="qw.shopType!=null">
            and oi.shop_type = #{qw.shopType}
        </if>
        <if test="qw.shipType!=null">
            and oi.ship_type = #{qw.shipType}
        </if>
        <if test="qw.hasPushErp!=null">
            and oi.has_push_erp = #{qw.hasPushErp}
        </if>
        <if test="qw.shipSupplier!=null">
            and oi.shipper_id = #{qw.shipSupplier}
        </if>
        <if test="qw.orderNum!=null and qw.orderNum !=''">
            and oi.order_num = #{qw.orderNum}
        </if>

        <if test="qw.refundStatus!=null">
            and oi.refund_status = #{qw.refundStatus}
        </if>
        <if test="qw.orderStatus!=null">
            and o.order_status = #{qw.orderStatus}
        </if>
        <if test="qw.shipStatus!=null">
            and oi.ship_status = #{qw.shipStatus}
        </if>
        <if test="qw.startTime!=null and qw.startTime != ''">
            and o.order_time &gt;= #{qw.startTime}
        </if>
        <if test="qw.endTime!=null and qw.endTime != ''">
            and o.order_time &lt;= #{qw.endTime}
        </if>
        <if test="qw.hasLink != null and qw.hasLink == 0">
            AND (oi.goods_sku_id is NULL or oi.goods_sku_id = 0)
        </if>
        <if test="qw.hasLink != null and qw.hasLink == 1">
            AND oi.goods_sku_id is NOT NULL and oi.goods_sku_id != 0
        </if>
        <if test="qw.merchantId!=null">
            and oi.merchant_id = #{qw.merchantId}
        </if>
        order by o.order_time desc
    </select>

    <select id="selectListVo" parameterType="cn.qihangerp.model.query.OrderItemQuery" resultType="cn.qihangerp.model.vo.OrderItemListVo">
        SELECT
        oi.*,o.shop_id,sh.name as shop_name,o.order_time,o.order_status
        FROM o_order_item as oi
        left join o_order as o on o.id = oi.order_id
        left join o_shop as sh on sh.id = o.shop_id

        WHERE 1=1
        <if test="qw.shopId!=null">
            and o.shop_id = #{qw.shopId}
        </if>
        <if test="qw.shipSupplier!=null">
            and oi.ship_supplier = #{qw.shipSupplier}
        </if>
        <if test="qw.orderNum!=null and qw.orderNum !=''">
            and oi.order_num = #{qw.orderNum}
        </if>
        <!--        <if test="qw.subOrderNum != null and qw.subOrderNum !=''">-->
        <!--            and oi.sub_order_num = #{qw.subOrderNum}-->
        <!--        </if>-->
        <if test="qw.refundStatus!=null">
            and oi.refund_status = #{qw.refundStatus}
        </if>
        <if test="qw.orderStatus!=null">
            and o.order_status = #{qw.orderStatus}
        </if>
        <if test="qw.shipStatus!=null">
            and oi.ship_status = #{qw.shipStatus}
        </if>
        <if test="qw.startTime!=null and qw.startTime != ''">
            and o.order_time &gt;= #{qw.startTime}
        </if>
        <if test="qw.endTime!=null and qw.endTime != ''">
            and o.order_time &lt;= #{qw.endTime}
        </if>


    </select>
    <select id="selectOrderItemListByOrderId" parameterType="Long" resultType="cn.qihangerp.model.vo.OrderItemListVo">
        SELECT
        oi.*,o.shop_id,o.order_time,gs.outer_erp_sku_id
        FROM o_order_item as oi
        left join o_order as o on o.id = oi.order_id
        left join o_goods_sku as gs on gs.id = oi.goods_sku_id
        WHERE oi.order_id = #{orderId}

    </select>
    <select id="selectTopSku" resultType="cn.qihangerp.model.vo.SalesTopSkuVo">
        SELECT
            sku_num as `name`,
            SUM(quantity) AS `value`
        FROM
            o_order_item
        WHERE
            create_time BETWEEN #{startDate} AND #{endDate}
          AND sku_num IS NOT NULL AND sku_num != ''
        GROUP BY
            sku_num
        ORDER BY
            `value` DESC
            LIMIT 10;
    </select>


    <select id="selectOrderItemWaitPushSupplierOrderIdList" resultType="java.lang.Long">
        SELECT DISTINCT oi.order_id
        FROM o_order_item as oi
        left join o_order as o on o.id = oi.order_id
        WHERE
        oi.shipper_id > 0
        and oi.ship_type = 300
        and oi.refund_status = 1
        and o.order_status = 1
        and oi.has_push_erp = 0
        <if test="merchantId != null">
            and oi.merchant_id = #{merchantId}
        </if>

        order by oi.order_id asc
    </select>

    <select id="selectOrderItemWaitPushCloudWarehouseOrderIdList" resultType="java.lang.Long">
        SELECT DISTINCT oi.order_id
        FROM o_order_item as oi
        left join o_order as o on o.id = oi.order_id
        WHERE
        oi.shipper_id > 0
        and oi.ship_type = 200
        and oi.refund_status = 1
        and o.order_status = 1
        and oi.has_push_erp = 0
        <if test="merchantId != null">
            and oi.merchant_id = #{merchantId}
        </if>

        order by oi.order_id asc
    </select>

</mapper>
